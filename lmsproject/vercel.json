{
  "builds": [
    {
      "src": "lmsproject/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "lmsproject/wsgi.py"
    }
  ]
}